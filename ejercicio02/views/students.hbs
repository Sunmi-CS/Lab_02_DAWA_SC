<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{title}}</title>
</head>
<body>
    <h1>Lista de estudiantes</h1>

    <table border="1">
        <tr>
            <th>Nombre</th>
            <th>Nota</th>
        </tr>

        {{#each students}}
        <tr>
            <td>{{name}}</td>
            
            {{#if (gt grade 15)}}
                <td style="color: green;"><strong>{{grade}}</strong></td>
            {{else}}
                <td>{{grade}}</td>
            {{/if}}

        </tr>
        {{/each}}
    </table>

    <a href="/">Volver</a>
</body>
</html>